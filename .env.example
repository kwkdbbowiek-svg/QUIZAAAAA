# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/eduquiz
REDIS_URL=redis://localhost:6379/0

# Telegram Bot
BOT_TOKEN=your_bot_token_here
WEBAPP_URL=https://your-app.railway.app

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Railway Production (Set these in Railway Dashboard)
# DATABASE_URL - automatically provided by Railway PostgreSQL
# REDIS_URL - automatically provided by Railway Redis
# BOT_TOKEN
# SECRET_KEY
